{
  "scripts": {
    "lf_dataplane_test.py": {
      "name": "lf_dataplane_test.py",
      "path": "py-scripts/lf_dataplane_test.py",

      "required": [
        "station",
        "upstream",
        "speed"
      ],

      "optional": [
        "duration",
        "traffic_directions",
        "traffic_types",
        "bandwidths",
        "channels",
        "dut",
        "verbosity",
        "json"
      ],

      "arguments": [
        {
          "dest": "station",
          "type": "station",
          "help": "Station used in the test"
        },
        {
          "dest": "upstream",
          "type": "ethernet",
          "help": "Upstream ethernet port"
        },
        {
          "dest": "speed",
          "type": "string",
          "help": "Traffic speed"
        },
        {
          "dest": "duration",
          "type": "string",
          "help": "Duration of test"
        },
        {
          "dest": "traffic_directions",
          "type": "string"
        },
        {
          "dest": "traffic_types",
          "type": "string"
        },
        {
          "dest": "bandwidths",
          "type": "string"
        },
        {
          "dest": "channels",
          "type": "string"
        },
        {
          "dest": "dut",
          "type": "string"
        },
        {
          "dest": "verbosity",
          "type": "int"
        },
        {
          "dest": "json",
          "type": "path"
        }
      ],

      "resources": {
        "station": "station",
        "upstream": "ethernet"
      },

      "example": "python3 lf_dataplane_test.py --station 1.1.sta0000 --upstream 1.1.eth2 --speed 1Gbps"
    }
  }
}